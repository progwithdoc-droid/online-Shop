# Server
PORT=5000
NODE_ENV=development

# Database (NeonDB / PostgreSQL)
# For local testing, use: postgresql://postgres:password@localhost:5432/sparkit?sslmode=disable
# For NeonDB production, use: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Configuration
# Enforce minimum 32 chars length for JWT_SECRET
JWT_SECRET=your_jwt_secret_here_must_be_at_least_32_characters_long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (for CORS validation)
CLIENT_URL=http://localhost:5173

# [PHASE 2] Razorpay Payments
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# [PHASE 2] Redis / Upstash Cache
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
